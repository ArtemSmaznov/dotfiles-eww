(defwidget slider [icon value onchange]
           (box :class "status-widget slider"
                :orientation "horizontal"
                :space-evenly false
                :spacing status-bar-icon-spacing

                (icon :icon icon)
                (scale :min 0
                       :max 100
                       :active {onchange != ""}
                       :value value
                       :onchange onchange)))
